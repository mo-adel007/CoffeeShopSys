<Window x:Class="CornerPos.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Corner" Width="440" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource AppFont}">

    <Border Margin="24" CornerRadius="20" Background="{StaticResource CardBrush}" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="0" Opacity="0.28" Color="#3E2723"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="176"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Espresso header -->
            <Border Grid.Row="0" Background="{StaticResource EspressoBrush}"
                    MouseLeftButtonDown="Header_Drag">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#x2615;" FontSize="46" HorizontalAlignment="Center" Foreground="#F5EFE6"/>
                        <TextBlock Text="Corner" FontSize="30" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="نقطة البيع" FontSize="13"
                                   Foreground="{StaticResource CaramelBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Style="{StaticResource IconButton}" Content="&#x2715;"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="40,32,40,0">
                <TextBlock Text="مرحباً بعودتك" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="سجّل الدخول لبدء ورديتك" FontSize="13"
                           Foreground="{StaticResource MutedBrush}" Margin="0,2,0,20"/>

                <TextBlock Text="اسم المستخدم" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="2,0,0,6"/>
                <TextBox x:Name="Username" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="كلمة المرور" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="2,16,0,6"/>
                <PasswordBox x:Name="Password" Style="{StaticResource ModernPasswordBox}"
                             KeyDown="Pass_KeyDown"/>

                <TextBlock x:Name="Error" Foreground="{StaticResource DangerBrush}" FontSize="12.5"
                           TextWrapping="Wrap" Margin="2,12,0,0" MinHeight="18"/>

                <Button Content="دخول" Style="{StaticResource PrimaryButton}"
                        Margin="0,14,0,0" Click="Login_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
