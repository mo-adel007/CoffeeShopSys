<UserControl x:Class="CornerPos.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Grid of users -->
        <DataGrid x:Name="Grid" Grid.Column="0" Margin="0,0,20,0"
                  Style="{StaticResource ModernDataGrid}" SelectionChanged="Grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username" Binding="{Binding username}" Width="2*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding time_work}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Add / edit form -->
        <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock x:Name="FormTitle" Text="Add user" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource EspressoBrush}" Margin="0,0,0,16"/>

                <TextBlock Text="USERNAME" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="2,0,0,6"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="2,14,0,6"/>
                <PasswordBox x:Name="PassBox" Style="{StaticResource ModernPasswordBox}"/>
                <TextBlock x:Name="PassHint" Text="Leave blank to keep current password"
                           FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="2,4,0,0"
                           Visibility="Collapsed"/>

                <TextBlock Text="ROLE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="2,14,0,6"/>
                <ComboBox x:Name="RoleBox" Height="40" FontSize="14" SelectedValuePath="Tag">
                    <ComboBoxItem Content="Administrator" Tag="admin"/>
                    <ComboBoxItem Content="Cashier" Tag="user"/>
                </ComboBox>

                <TextBlock x:Name="Error" Foreground="{StaticResource DangerBrush}" FontSize="12.5"
                           TextWrapping="Wrap" Margin="2,12,0,0" MinHeight="16"/>

                <Button x:Name="SaveBtn" Content="Add user" Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0" Click="Save_Click"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="NewBtn" Grid.Column="0" Content="New" Style="{StaticResource GhostButton}" Click="New_Click"/>
                    <Button x:Name="DeleteBtn" Grid.Column="2" Content="Delete" Style="{StaticResource DangerButton}"
                            Click="Delete_Click" IsEnabled="False"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
