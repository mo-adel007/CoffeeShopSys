<UserControl x:Class="CornerPos.CloseDayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}"
             Background="{StaticResource CreamBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="تقفيل اليوم" FontSize="24" FontWeight="SemiBold"
                   Foreground="{StaticResource EspressoBrush}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CaramelBrush}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="مبيعات المنتجات" FontSize="14" Foreground="White" Opacity="0.9"/>
                    <TextBlock x:Name="SalesText" Text="0.00" FontSize="28" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1.5" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="إيداعات الخزنة" FontSize="14" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="DepositsText" Text="0.00" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1.5" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="مصروفات ومسحوبات" FontSize="14" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="OutText" Text="0.00" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="مبيعات المنتجات" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="SellsGrid" Style="{StaticResource ModernDataGrid}" AutoGenerateColumns="True"/>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="حركة الخزنة (إيداع / سحب / مصروفات)" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="MovesGrid" Style="{StaticResource ModernDataGrid}" AutoGenerateColumns="True"/>
            </Grid>
        </Grid>

        <Button Grid.Row="3" x:Name="CloseBtn" Content="تقفيل اليوم" Style="{StaticResource PrimaryButton}"
                Width="220" HorizontalAlignment="Left" Margin="0,20,0,0" Click="Close_Click"/>
    </Grid>
</UserControl>
