<UserControl x:Class="CornerPos.CloseMonthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="تقفيل الشهر" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource EspressoBrush}" Margin="0,0,0,18"/>

        <!-- Total cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="16"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="مبيعات المنتجات" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="IncomeText" Text="0.00" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource EspressoBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="16"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="إيداعات الخزنة" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="DepositsText" Text="0.00" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource EspressoBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{StaticResource CardBrush}" CornerRadius="16"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="مصروفات ومسحوبات" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="ExpensesText" Text="0.00" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource EspressoBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Background="{StaticResource CaramelBrush}" CornerRadius="16"
                    BorderThickness="0" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="الربح" FontSize="11" FontWeight="SemiBold" Foreground="#FFF3E6"/>
                    <TextBlock x:Name="ProfitText" Text="0.00" FontSize="24" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Two grids -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="الأيام" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource EspressoBrush}" Margin="2,0,0,8"/>
                <DataGrid x:Name="DaysGrid" Style="{StaticResource ModernDataGrid}" AutoGenerateColumns="True"/>
            </DockPanel>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="المصروفات الشهرية" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource EspressoBrush}" Margin="2,0,0,8"/>
                <DataGrid x:Name="ExpensesGrid" Style="{StaticResource ModernDataGrid}" AutoGenerateColumns="True"/>
            </DockPanel>
        </Grid>

        <!-- Close month button -->
        <Button x:Name="CloseMonthBtn" Grid.Row="3" Content="تقفيل الشهر" Style="{StaticResource PrimaryButton}"
                Width="220" HorizontalAlignment="Right" Margin="0,20,0,0" Click="CloseMonth_Click"/>
    </Grid>
</UserControl>
