<Window x:Class="CornerPos.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Corner — الترخيص" Width="560" Height="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource CreamBrush}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource AppFont}">

    <Border Margin="26" CornerRadius="18" Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <StackPanel Margin="32,28">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <TextBlock Text="&#x2615;" FontSize="30" Foreground="{StaticResource CaramelBrush}"/>
                <TextBlock Text="ترخيص Corner" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="{StaticResource EspressoBrush}"/>
            </StackPanel>

            <!-- Current status line (trial days / expiry / expired) -->
            <Border x:Name="StatusBadge" CornerRadius="10" Padding="14,10" Margin="0,12,0,4"
                    Background="{StaticResource CreamBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <TextBlock x:Name="StatusText" TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
            </Border>

            <TextBlock Text="أدخل مفتاح الترخيص:" Margin="2,16,0,6"
                       FontSize="13.5" Foreground="{StaticResource MutedBrush}"/>
            <TextBox x:Name="KeyBox" Style="{StaticResource ModernTextBox}"
                     Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalContentAlignment="Top" Padding="12,8"/>

            <TextBlock x:Name="Message" TextWrapping="Wrap" Margin="2,10,0,0"
                       FontSize="13" Foreground="{StaticResource DangerBrush}"/>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ActivateBtn" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                        Content="تفعيل" Click="Activate_Click"/>
                <Button x:Name="SecondaryBtn" Grid.Column="2" Style="{StaticResource GhostButton}"
                        Width="120" Content="خروج" Click="Secondary_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
