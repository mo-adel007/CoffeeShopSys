<UserControl x:Class="CornerPos.CashierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="368"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Products ===== -->
        <DockPanel Grid.Column="0" Margin="0,0,20,0">
            <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Margin="0,0,0,14">
                <ItemsControl x:Name="CategoryList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" Tag="{Binding Id}" Click="Category_Click"
                                    Style="{StaticResource ChipButton}" Margin="0,0,8,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ProductList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="152" Height="88" Margin="0,0,12,12" Tag="{Binding}"
                                    Click="Product_Click" Style="{StaticResource TileButton}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap" TextAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding PriceText}" TextAlignment="Center"
                                               Foreground="{StaticResource CaramelBrush}" FontWeight="Bold" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ===== Order cart ===== -->
        <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel Margin="18">
                <TextBlock DockPanel.Dock="Top" Text="Current Order" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource EspressoBrush}" Margin="0,0,0,12"/>

                <!-- Footer: total + actions -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10"/>
                    <Grid Margin="2,0,2,12">
                        <TextBlock Text="Total" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="TotalText" Text="0.00" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource EspressoBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Button Content="Charge" Style="{StaticResource PrimaryButton}" Click="Charge_Click"/>
                    <Button Content="Clear order" Style="{StaticResource GhostButton}" Margin="0,8,0,0" Click="Clear_Click"/>
                </StackPanel>

                <!-- Cart items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl x:Name="CartList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CreamBrush}" CornerRadius="10" Padding="10,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="{Binding LineText}" FontSize="12"
                                                           Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#8722;" Style="{StaticResource QtyButton}" Tag="{Binding}" Click="Minus_Click"/>
                                                <TextBlock Text="{Binding Qty}" MinWidth="26" TextAlignment="Center"
                                                           VerticalAlignment="Center" FontWeight="Bold"
                                                           Foreground="{StaticResource TextBrush}"/>
                                                <Button Content="+" Style="{StaticResource QtyButton}" Tag="{Binding}" Click="Plus_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="EmptyHint" Text="Tap a product to start an order."
                                   Foreground="{StaticResource MutedBrush}" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,30,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
