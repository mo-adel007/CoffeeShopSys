<UserControl x:Class="CornerPos.MonthlyExpensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Grid of monthly expenses -->
        <DataGrid x:Name="Grid" Grid.Column="0" Margin="0,0,20,0"
                  Style="{StaticResource ModernDataGrid}" SelectionChanged="Grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="المصروف" Binding="{Binding expens_name}" Width="2.2*"/>
                <DataGridTextColumn Header="السعر" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Add form -->
        <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock x:Name="FormTitle" Text="إضافة مصروف" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource EspressoBrush}" Margin="0,0,0,16"/>

                <TextBlock Text="الاسم" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="2,0,0,6"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="السعر" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="2,14,0,6"/>
                <TextBox x:Name="PriceBox" Style="{StaticResource ModernTextBox}"/>

                <TextBlock x:Name="Error" Foreground="{StaticResource DangerBrush}" FontSize="12.5"
                           TextWrapping="Wrap" Margin="2,12,0,0" MinHeight="16"/>

                <Button x:Name="SaveBtn" Content="إضافة مصروف" Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0" Click="Save_Click"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="NewBtn" Grid.Column="0" Content="جديد" Style="{StaticResource GhostButton}" Click="New_Click"/>
                    <Button x:Name="DeleteBtn" Grid.Column="2" Content="حذف" Style="{StaticResource DangerButton}"
                            Click="Delete_Click" IsEnabled="False"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
